# ============================================
# Atollom AI — Variables de Entorno (Backend)
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el archivo .env a Git.
# ============================================

# Supabase
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key
SUPABASE_JWT_SECRET=tu_jwt_secret

# Bind ERP
BIND_API_BASE_URL=https://api.bind.com.mx/api

# Redis & Rate Limiting (Opcional en dev, el fallback es in-memory)
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_MAX_REQUESTS_PER_DAY=200
RATE_LIMIT_MAX_BIND_CALLS_PER_DAY=50

# App Security
APP_ENCRYPTION_KEY=una_clave_maestra_segura_para_pgcrypto

# Modelos LLM (Para integración futura)
LLM_PROVIDER=none
LLM_API_KEY=
LLM_PRIMARY_MODEL=
LLM_BACKUP_MODEL=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Debug
DEBUG=true
LOG_LEVEL=INFO
